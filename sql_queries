conn = sqlite3.connect(':memory:')

users.to_sql('user_table',          conn, index=False, if_exists='replace')
home.to_sql('home_page',            conn, index=False, if_exists='replace')
search.to_sql('search_page',        conn, index=False, if_exists='replace')
payment.to_sql('payment_page',      conn, index=False, if_exists='replace')
confirm.to_sql('confirmation_page', conn, index=False, if_exists='replace')

print("All tables loaded successfully!")

query = """
SELECT 'Home Page'       AS step, 1 AS order_num, COUNT(*) AS users FROM home_page
UNION ALL
SELECT 'Search Page'     AS step, 2,               COUNT(*) AS users FROM search_page
UNION ALL
SELECT 'Payment Page'    AS step, 3,               COUNT(*) AS users FROM payment_page
UNION ALL
SELECT 'Confirmation'    AS step, 4,               COUNT(*) AS users FROM confirmation_page
"""
pd.read_sql(query, conn)

query = """
WITH funnel AS (
    SELECT 'Home Page'    AS step, 1 AS order_num, COUNT(*) AS users FROM home_page
    UNION ALL
    SELECT 'Search Page'  AS step, 2, COUNT(*) FROM search_page
    UNION ALL
    SELECT 'Payment Page' AS step, 3, COUNT(*) FROM payment_page
    UNION ALL
    SELECT 'Confirmation' AS step, 4, COUNT(*) FROM confirmation_page
)
SELECT
    step,
    users,
    ROUND(users * 100.0 / LAG(users) OVER (ORDER BY order_num), 1) AS step_conv_pct,
    ROUND(users * 100.0 / FIRST_VALUE(users) OVER (ORDER BY order_num), 1) AS overall_conv_pct
FROM funnel
"""
pd.read_sql(query, conn)

query = """
SELECT
    u.gender,
    COUNT(DISTINCT h.user_id)  AS home_users,
    COUNT(DISTINCT s.user_id)  AS search_users,
    COUNT(DISTINCT p.user_id)  AS payment_users,
    COUNT(DISTINCT c.user_id)  AS confirm_users,
    ROUND(COUNT(DISTINCT c.user_id) * 100.0 / COUNT(DISTINCT h.user_id), 1) AS conv_pct
FROM home_page h
LEFT JOIN search_page       s ON h.user_id = s.user_id
LEFT JOIN payment_page      p ON h.user_id = p.user_id
LEFT JOIN confirmation_page c ON h.user_id = c.user_id
JOIN user_table             u ON h.user_id = u.user_id
GROUP BY u.gender
"""
pd.read_sql(query, conn)

